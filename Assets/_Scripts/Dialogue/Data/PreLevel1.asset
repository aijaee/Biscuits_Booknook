  m_Script: {fileID: 11500000, guid: 46d65186db4a01a4a81669d25d37f726, type: 3}
  m_Name: PreLevel1
  m_EditorClassIdentifier: 
  lines:
  - speakerName: Lottie
    portraitSprite: {fileID: 21300000, guid: 33bd663ffdc92ff4997502d7b732102e, type: 3}
    animatorController: {fileID: 9100000, guid: 0bd5f34aaa2626549b7961cd5c29373b, type: 2}
    nameImage: {fileID: 21300000, guid: d5deadc078a914a448fb88bc4334fa60, type: 3}
    text: "Biscuit\u2026 I found this book called \u2018<i>Exploring Your Favorite
      Seafoods and Where to Find Them.</i>\u2019 But\u2026 I can\u2019t read it!
      There are scribbles all over the pages!"
    walkIn: 1
    walkOut: 0
  - speakerName: Biscuit
    portraitSprite: {fileID: 21300000, guid: 33bd663ffdc92ff4997502d7b732102e, type: 3}
    animatorController: {fileID: 0}
    nameImage: {fileID: 21300000, guid: c57f27e20edf34642a942929da7b4a13, type: 3}
    text: Scribbles again? Oh no! They must be trying to hide the stories.
    walkIn: 0
    walkOut: 0
  - speakerName: Lottie
    portraitSprite: {fileID: 21300000, guid: 33bd663ffdc92ff4997502d7b732102e, type: 3}
    animatorController: {fileID: 9100000, guid: 0bd5f34aaa2626549b7961cd5c29373b, type: 2}
    nameImage: {fileID: 21300000, guid: d5deadc078a914a448fb88bc4334fa60, type: 3}
    text: "I really want to read it, but I can\u2019t understand anything\u2026"
    walkIn: 0
    walkOut: 0
  - speakerName: Biscuit
    portraitSprite: {fileID: 21300000, guid: 33bd663ffdc92ff4997502d7b732102e, type: 3}
    animatorController: {fileID: 0}
    nameImage: {fileID: 21300000, guid: c57f27e20edf34642a942929da7b4a13, type: 3}
    text: "Don\u2019t worry, Lottie. I\u2019ll cleanse the book and chase those scribbles
      away!"
    walkIn: 0
    walkOut: 0
  - speakerName: Lottie
    portraitSprite: {fileID: 21300000, guid: 33bd663ffdc92ff4997502d7b732102e, type: 3}
    animatorController: {fileID: 9100000, guid: 0bd5f34aaa2626549b7961cd5c29373b, type: 2}
    nameImage: {fileID: 21300000, guid: d5deadc078a914a448fb88bc4334fa60, type: 3}
    text: "You will? That\u2019s awesome!"
    walkIn: 0
    walkOut: 0
  - speakerName: Biscuit
    portraitSprite: {fileID: 21300000, guid: 33bd663ffdc92ff4997502d7b732102e, type: 3}
    animatorController: {fileID: 0}
    nameImage: {fileID: 21300000, guid: c57f27e20edf34642a942929da7b4a13, type: 3}
    text: "Of course! Just wait here. Soon, you\u2019ll be reading all about seafood
      adventures."
    walkIn: 0
    walkOut: 0
