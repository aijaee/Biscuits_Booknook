%TAG !u! tag:unity3d.com,2011:
--- !u!114 &11400000
MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 0}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: 46d65186db4a01a4a81669d25d37f726, type: 3}
  m_Name: PostLevel1
  m_EditorClassIdentifier: 
  lines:
  - speakerName: Biscuit
    portraitSprite: {fileID: 21300000, guid: 33bd663ffdc92ff4997502d7b732102e, type: 3}
    animatorController: {fileID: 0}
    nameImage: {fileID: 21300000, guid: c57f27e20edf34642a942929da7b4a13, type: 3}
    text: Mission complete! The scribbles are gone.
    walkIn: 1
    walkOut: 0
  - speakerName: Lottie
    portraitSprite: {fileID: 21300000, guid: 33bd663ffdc92ff4997502d7b732102e, type: 3}
    animatorController: {fileID: 9100000, guid: 0bd5f34aaa2626549b7961cd5c29373b, type: 2}
    nameImage: {fileID: 21300000, guid: d5deadc078a914a448fb88bc4334fa60, type: 3}
    text: "Wow! The words are back! I can finally read \u2018<i>Exploring Your Favorite
      Seafoods and Where They Live.</i>\u2019"
    walkIn: 0
    walkOut: 0
  - speakerName: Biscuit
    portraitSprite: {fileID: 21300000, guid: 33bd663ffdc92ff4997502d7b732102e, type: 3}
    animatorController: {fileID: 0}
    nameImage: {fileID: 21300000, guid: c57f27e20edf34642a942929da7b4a13, type: 3}
    text: Every book deserves to be read. Enjoy your sea adventure, Lottie!
    walkIn: 0
    walkOut: 0
  - speakerName: Lottie
    portraitSprite: {fileID: 21300000, guid: 33bd663ffdc92ff4997502d7b732102e, type: 3}
    animatorController: {fileID: 9100000, guid: 0bd5f34aaa2626549b7961cd5c29373b, type: 2}
    nameImage: {fileID: 21300000, guid: d5deadc078a914a448fb88bc4334fa60, type: 3}
    text: "Thanks, Biscuit! You\u2019re the best."
    walkIn: 0
    walkOut: 0
  - speakerName: Biscuit
    portraitSprite: {fileID: 21300000, guid: 33bd663ffdc92ff4997502d7b732102e, type: 3}
    animatorController: {fileID: 0}
    nameImage: {fileID: 21300000, guid: c57f27e20edf34642a942929da7b4a13, type: 3}
    text: "Anytime! I\u2019ll keep my eyes open for more scribbly trouble."
    walkIn: 0
    walkOut: 1
  - speakerName: Sir B. Cheese
    portraitSprite: {fileID: 21300000, guid: 3279881bdf1484842986d380491a0351, type: 3}
    animatorController: {fileID: 9100000, guid: 72fcf1f1642c6b04b9c3adaf132e8274, type: 2}
    nameImage: {fileID: 21300000, guid: 3078039a58ee8754984fbc66a9382421, type: 3}
    text: "Biscuit\u2026 I borrowed this book called \u2018<i>The Giving Tree.</i>\u2019
      I really want to read it\u2026 but there are scribbles everywhere."
    walkIn: 1
    walkOut: 0
  - speakerName: Biscuit
    portraitSprite: {fileID: 21300000, guid: 3279881bdf1484842986d380491a0351, type: 3}
    animatorController: {fileID: 0}
    nameImage: {fileID: 21300000, guid: c57f27e20edf34642a942929da7b4a13, type: 3}
    text: Oh no! Scribbles again?
    walkIn: 0
    walkOut: 0
  - speakerName: Sir B. Cheese
    portraitSprite: {fileID: 21300000, guid: 3279881bdf1484842986d380491a0351, type: 3}
    animatorController: {fileID: 9100000, guid: 72fcf1f1642c6b04b9c3adaf132e8274, type: 2}
    nameImage: {fileID: 21300000, guid: 3078039a58ee8754984fbc66a9382421, type: 3}
    text: "Yes\u2026 I tried reading it, but I can\u2019t see the real words."
    walkIn: 0
    walkOut: 0
  - speakerName: Biscuit
    portraitSprite: {fileID: 21300000, guid: 3279881bdf1484842986d380491a0351, type: 3}
    animatorController: {fileID: 0}
    nameImage: {fileID: 21300000, guid: c57f27e20edf34642a942929da7b4a13, type: 3}
    text: "Don\u2019t worry, Sir Cheese. I\u2019ll clear out those scribbles and
      make the story shine again."
    walkIn: 0
    walkOut: 0
  - speakerName: Sir B. Cheese
    portraitSprite: {fileID: 21300000, guid: 3279881bdf1484842986d380491a0351, type: 3}
    animatorController: {fileID: 9100000, guid: 72fcf1f1642c6b04b9c3adaf132e8274, type: 2}
    nameImage: {fileID: 21300000, guid: 3078039a58ee8754984fbc66a9382421, type: 3}
    text: Really? You'll fix it?
    walkIn: 0
    walkOut: 0
  - speakerName: Biscuit
    portraitSprite: {fileID: 21300000, guid: 3279881bdf1484842986d380491a0351, type: 3}
    animatorController: {fileID: 0}
    nameImage: {fileID: 21300000, guid: c57f27e20edf34642a942929da7b4a13, type: 3}
    text: "Of course! You\u2019ll be reading \u2018<i>The Giving Tree</i>\u2019 in
      no time."
    walkIn: 0
    walkOut: 0
  - speakerName: Sir B. Cheese
    portraitSprite: {fileID: 21300000, guid: 3279881bdf1484842986d380491a0351, type: 3}
    animatorController: {fileID: 9100000, guid: 72fcf1f1642c6b04b9c3adaf132e8274, type: 2}
    nameImage: {fileID: 21300000, guid: 3078039a58ee8754984fbc66a9382421, type: 3}
    text: "Thank you, Biscuit! I\u2019ve always wanted to know what happens in this
      story."
    walkIn: 0
    walkOut: 1
