  lines:
  - speakerName: Sisu
    portraitSprite: {fileID: 21300000, guid: c36c0caf0c9c9234b9f3021c71580f70, type: 3}
    animatorController: {fileID: 9100000, guid: 0670a23ec18c2ed438a63523041ad31c, type: 2}
    nameImage: {fileID: 21300000, guid: 8c8402ad90ecccb4690d155d3e547d40, type: 3}
    text: Well done, Biscuit. You have completed what was asked of you.
    walkIn: 0
    walkOut: 0
    playOpenBoxAnimation: 0
  - speakerName: Sisu
    portraitSprite: {fileID: 21300000, guid: c36c0caf0c9c9234b9f3021c71580f70, type: 3}
    animatorController: {fileID: 9100000, guid: 0670a23ec18c2ed438a63523041ad31c, type: 2}
    nameImage: {fileID: 21300000, guid: a233f0dacbb7aad44b4ecc31921969d2, type: 3}
    text: "Name\u2019s <b><color=#0f60db>Sisu</b></color>. I travel these halls trading
      wares and wisdom."
    walkIn: 0
    walkOut: 0
    playOpenBoxAnimation: 0
  - speakerName: Sisu
    portraitSprite: {fileID: 21300000, guid: c36c0caf0c9c9234b9f3021c71580f70, type: 3}
    animatorController: {fileID: 9100000, guid: 0670a23ec18c2ed438a63523041ad31c, type: 2}
    nameImage: {fileID: 21300000, guid: a233f0dacbb7aad44b4ecc31921969d2, type: 3}
    text: "You probably noticed I kept quiet at first\u2026 I like to see who\u2019s
      capable before I strike up a conversation\u2014<b><color=#f29900>or a deal.</b></color>"
    walkIn: 0
    walkOut: 0
    playOpenBoxAnimation: 0
  - speakerName: Sisu
    portraitSprite: {fileID: 21300000, guid: c36c0caf0c9c9234b9f3021c71580f70, type: 3}
    animatorController: {fileID: 9100000, guid: 0670a23ec18c2ed438a63523041ad31c, type: 2}
    nameImage: {fileID: 21300000, guid: a233f0dacbb7aad44b4ecc31921969d2, type: 3}
    text: The path ahead is now <b><color=#0f60db>open</color></b>. May fortune guide
      you beyond this chamber.
    walkIn: 0
    walkOut: 1
    playOpenBoxAnimation: 1
