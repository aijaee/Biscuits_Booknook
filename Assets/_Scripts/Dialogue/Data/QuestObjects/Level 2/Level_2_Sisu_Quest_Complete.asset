MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 0}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: 46d65186db4a01a4a81669d25d37f726, type: 3}
  m_Name: Level_2_Sisu_Quest_Complete
  m_EditorClassIdentifier: 
  lines:
  - speakerName: Sisu
    portraitSprite: {fileID: 21300000, guid: c36c0caf0c9c9234b9f3021c71580f70, type: 3}
    animatorController: {fileID: 9100000, guid: 0670a23ec18c2ed438a63523041ad31c, type: 2}
    nameImage: {fileID: 21300000, guid: a233f0dacbb7aad44b4ecc31921969d2, type: 3}
    text: You did well, Biscuit. Another task finished without complaint.
    walkIn: 0
    walkOut: 0
    playOpenBoxAnimation: 0
  - speakerName: Sisu
    portraitSprite: {fileID: 21300000, guid: c36c0caf0c9c9234b9f3021c71580f70, type: 3}
    animatorController: {fileID: 9100000, guid: 0670a23ec18c2ed438a63523041ad31c, type: 2}
    nameImage: {fileID: 21300000, guid: a233f0dacbb7aad44b4ecc31921969d2, type: 3}
    text: "I pay attention to how people move, and you\u2019re fast\u2014but you\u2019re
      holding back between those bursts."
    walkIn: 0
    walkOut: 0
    playOpenBoxAnimation: 0
  - speakerName: Sisu
    portraitSprite: {fileID: 21300000, guid: c36c0caf0c9c9234b9f3021c71580f70, type: 3}
    animatorController: {fileID: 9100000, guid: 0670a23ec18c2ed438a63523041ad31c, type: 2}
    nameImage: {fileID: 21300000, guid: a233f0dacbb7aad44b4ecc31921969d2, type: 3}
    text: "So here\u2019s something useful\u2014learn to recover quicker after a
      dash. Move, breathe, and get right back into the fight."
    walkIn: 0
    walkOut: 0
    playOpenBoxAnimation: 1
  - speakerName: Sisu
    portraitSprite: {fileID: 21300000, guid: c36c0caf0c9c9234b9f3021c71580f70, type: 3}
    animatorController: {fileID: 9100000, guid: 0670a23ec18c2ed438a63523041ad31c, type: 2}
    nameImage: {fileID: 21300000, guid: a233f0dacbb7aad44b4ecc31921969d2, type: 3}
    text: "<b><color=#0f60db>I\u2019ve shortened the time between your dashes</b></color>\u2014make
      it count. Consider it earned, not given. I don\u2019t hand out advantages for
      free."
    walkIn: 0
    walkOut: 0
    playOpenBoxAnimation: 0
  - speakerName: Sisu
    portraitSprite: {fileID: 21300000, guid: c36c0caf0c9c9234b9f3021c71580f70, type: 3}
    animatorController: {fileID: 9100000, guid: 0670a23ec18c2ed438a63523041ad31c, type: 2}
    nameImage: {fileID: 21300000, guid: a233f0dacbb7aad44b4ecc31921969d2, type: 3}
    text: "Now then\u2026the path ahead has <b><color=#0f60db>opened</b></color>
      again. Be careful."
    walkIn: 0
    walkOut: 0
    playOpenBoxAnimation: 0
  - speakerName: Sisu
    portraitSprite: {fileID: 21300000, guid: c36c0caf0c9c9234b9f3021c71580f70, type: 3}
    animatorController: {fileID: 9100000, guid: 0670a23ec18c2ed438a63523041ad31c, type: 2}
    nameImage: {fileID: 21300000, guid: a233f0dacbb7aad44b4ecc31921969d2, type: 3}
    text: "Step forward when you\u2019re ready, and <b><color=#0f60db>mind your footing.</b></color>"
    walkIn: 0
    walkOut: 1
    playOpenBoxAnimation: 0
