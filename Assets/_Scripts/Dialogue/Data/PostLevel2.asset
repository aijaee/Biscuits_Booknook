  - speakerName: Biscuit
    portraitSprite: {fileID: 21300000, guid: 3279881bdf1484842986d380491a0351, type: 3}
    animatorController: {fileID: 0}
    nameImage: {fileID: 21300000, guid: c57f27e20edf34642a942929da7b4a13, type: 3}
    text: Every story should be read and shared. Enjoy your reading, Sir Cheese.
