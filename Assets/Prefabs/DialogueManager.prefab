--- !u!114 &6922286031048573105
MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 4050974506736665783}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: 0d2b29b8cc6331143ad541e9c12e9227, type: 3}
  m_Name: 
  m_EditorClassIdentifier: 
  storySceneRoot: {fileID: 6166741521748839794}
  storyCanvasGroup: {fileID: 5985144044306437234}
  fadeImage: {fileID: 269746079369480758}
  nameImage: {fileID: 7112598337804092606}
  dialogueText: {fileID: 929458516794773911}
  nextIndicator: {fileID: 0}
  npcs: []
  talkingParam: isTalking
  fadeDuration: 1
  typeSpeed: 0.03
  dialogueEntries:
  - characterNameImage: {fileID: 21300000, guid: d5deadc078a914a448fb88bc4334fa60, type: 3}
    text: "Biscuit\u2026 I found this book called \u2018Exploring Your Favorite Seafoods
      and Where to Find Them.\u2019 But\u2026 I can\u2019t read it! There are scribbles
      all over the pages!"
    speaker:
      name: Lottie
      image: {fileID: 3125931031480469260}
      animator: {fileID: 7106030767792029980}
    speakerVisible: 1
  - characterNameImage: {fileID: 21300000, guid: c57f27e20edf34642a942929da7b4a13, type: 3}
    text: Scribbles again? Oh no! They must be trying to hide the stories.
    speaker:
      name: Biscuit
      image: {fileID: 0}
      animator: {fileID: 0}
    speakerVisible: 0
  - characterNameImage: {fileID: 21300000, guid: d5deadc078a914a448fb88bc4334fa60, type: 3}
    text: "I really want to read it, but I can\u2019t understand anything\u2026"
    speaker:
      name: Lottie
      image: {fileID: 3125931031480469260}
      animator: {fileID: 7106030767792029980}
    speakerVisible: 1
  - characterNameImage: {fileID: 21300000, guid: c57f27e20edf34642a942929da7b4a13, type: 3}
    text: "Don\u2019t worry, Alex. I\u2019ll cleanse the book and chase those scribbles
      away!"
    speaker:
      name: Biscuit
      image: {fileID: 0}
      animator: {fileID: 0}
    speakerVisible: 0
  - characterNameImage: {fileID: 21300000, guid: d5deadc078a914a448fb88bc4334fa60, type: 3}
    text: "You will? That\u2019s awesome!"
    speaker:
      name: Lottie
      image: {fileID: 3125931031480469260}
      animator: {fileID: 7106030767792029980}
    speakerVisible: 1
  - characterNameImage: {fileID: 21300000, guid: c57f27e20edf34642a942929da7b4a13, type: 3}
    text: "Of course! Just wait here. Soon, you\u2019ll be reading all about seafood
      adventures."
    speaker:
      name: Biscuit
      image: {fileID: 0}
      animator: {fileID: 0}
    speakerVisible: 0
